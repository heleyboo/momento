# Database (docker-compose Postgres)
DATABASE_URL=postgres://momento:momento@localhost:5433/momento

# Storage provider: local | s3 | gcs | drive  (only `local` implemented in Phase 1)
STORAGE_PROVIDER=local
# Local adapter: host directory where media bytes are written (created if missing)
STORAGE_LOCAL_DIR=./.media

# Hard cap on a single uploaded file (bytes). Enforced by the streaming parser (Phase 3).
MAX_UPLOAD_BYTES=314572800

# --- Auth (Phase 2) ---
# iOS OAuth client ID; ID tokens from the app must have this as their audience.
GOOGLE_CLIENT_ID_IOS=YOUR_CLIENT_ID.apps.googleusercontent.com
# Secret for signing session access JWTs (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=change-me-in-production

# --- Added in later phases (kept here for reference) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
