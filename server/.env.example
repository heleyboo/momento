# Database (docker-compose Postgres)
DATABASE_URL=postgres://momento:momento@localhost:5433/momento

# Storage provider: local | s3 | gcs | drive  (switching providers = this var only)
STORAGE_PROVIDER=local
# --- local adapter ---
STORAGE_LOCAL_DIR=./.media
# --- s3 adapter (also works with MinIO: set S3_ENDPOINT) ---
# S3_BUCKET=momento
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000   # MinIO; omit for real AWS
# S3_ACCESS_KEY_ID=momento
# S3_SECRET_ACCESS_KEY=momento123
# --- gcs adapter ---
# GCS_BUCKET=momento
# GCS_KEY_FILE=./gcs-service-account.json   # or use GOOGLE_APPLICATION_CREDENTIALS
# --- drive adapter ---
# (no server env: the user's Drive access token is forwarded per request)

# Hard cap on a single uploaded file (bytes). Enforced by the streaming parser (Phase 3).
MAX_UPLOAD_BYTES=314572800

# --- Auth (Phase 2) ---
# iOS OAuth client ID; ID tokens from the app must have this as their audience.
GOOGLE_CLIENT_ID_IOS=YOUR_CLIENT_ID.apps.googleusercontent.com
# Secret for signing session access JWTs (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=change-me-in-production

# --- Added in later phases (kept here for reference) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
